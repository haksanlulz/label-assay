# Copy to .env (gitignored). Server-side only — never commit a real key, and the
# key is never sent to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# Daily spend guard (USD). When the app's own tally crosses this, the AI path
# refuses further labels (with a clean message) until the next day, so a public
# deployment can never run up an unbounded bill.
DAILY_BUDGET_USD=5
